# Anthropic API key — required for live (non-mock) runs.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used by every agent (defaults to claude-opus-4-8).
# FACTORY_MODEL=claude-opus-4-8

# Optional: force offline mock mode even when a key is present.
# FACTORY_MOCK=1
